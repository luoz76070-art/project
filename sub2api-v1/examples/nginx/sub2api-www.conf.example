map $http_upgrade $connection_upgrade {
    default "upgrade";
    '' "";
}

map "$http_user_agent|$http_originator" $codex_bridge_api_key {
    default "";
    ~*codex_ "__SUB2API_INTERNAL_KEY__";
}

map $codex_bridge_api_key $sub2api_forward_authorization {
    default $http_authorization;
    ~.+ "";
}

map $codex_bridge_api_key $sub2api_forward_x_api_key {
    default $http_x_api_key;
    ~.+ $codex_bridge_api_key;
}

map $codex_bridge_api_key $sub2api_forward_x_goog_api_key {
    default $http_x_goog_api_key;
    ~.+ "";
}

server {
    listen 80;
    listen [::]:80;
    server_name www.example.com;

    return 301 https://www.example.com$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name www.example.com;

    ssl_certificate /etc/nginx/ssl/example/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/example/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    client_max_body_size 256m;

    location / {
        proxy_pass http://127.0.0.1:18080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port 443;
        proxy_set_header Authorization $sub2api_forward_authorization;
        proxy_set_header x-api-key $sub2api_forward_x_api_key;
        proxy_set_header x-goog-api-key $sub2api_forward_x_goog_api_key;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_buffering off;
    }
}
